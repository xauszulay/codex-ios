#!/var/jb/usr/bin/zsh
# Codex CLI Authentication for iOS (Procursus / Dopamine)
# Mirrors the claude-auth flow: API key or ChatGPT OAuth login.

CODEX_HOME="/var/jb/usr/local/lib/codex"
NODE_BIN="$CODEX_HOME/node"
CONFIG_DIR="${HOME:-/var/jb/var/mobile}/.codex"

mkdir -p "$CONFIG_DIR"
chmod 0700 "$CONFIG_DIR" 2>/dev/null || true

echo ""
echo "=========================================="
echo "   Codex CLI iOS — Authentication"
echo "=========================================="
echo ""

echo "Choose authentication method:"
echo ""
echo "  1) OpenAI API Key (direct API billing)"
echo "     Get your key at: https://platform.openai.com/api-keys"
echo ""
echo "  2) Sign in with ChatGPT (Plus / Pro / Business / Edu / Enterprise)"
echo "     Uses your ChatGPT subscription"
echo ""
echo "  3) Check current auth status"
echo ""
printf "Enter choice [1-3]: "
read choice

case "$choice" in
    1)
        echo ""
        echo "Enter your OpenAI API key:"
        echo "(starts with sk-...)"
        echo ""
        printf "> "
        read -r api_key

        if [[ ! "$api_key" =~ ^sk- ]]; then
            echo ""
            echo "Error: Invalid API key format. Should start with 'sk-'."
            exit 1
        fi

        # Save to credentials file (sourced by codex wrapper).
        echo "export OPENAI_API_KEY=\"$api_key\"" > "$CONFIG_DIR/credentials"
        chmod 600 "$CONFIG_DIR/credentials"

        # Codex reads auth.toml under ~/.codex/auth.json — write a minimal one.
        cat > "$CONFIG_DIR/auth.json" << EOF
{
  "OPENAI_API_KEY": "$api_key"
}
EOF
        chmod 600 "$CONFIG_DIR/auth.json"

        echo ""
        echo "API key saved successfully!"
        echo ""
        echo "You can now run: codex"
        ;;

    2)
        echo ""
        echo "ChatGPT Sign-In"
        echo "==============="
        echo ""
        echo "On iOS, the ChatGPT OAuth flow requires a browser round-trip."
        echo "The Codex CLI native binary handles this itself: just run 'codex'"
        echo "and pick 'Sign in with ChatGPT' in the TUI. It will open Safari"
        echo "via uiopen and complete the loop automatically."
        echo ""
        echo "If that fails, use option 1 (API key) instead."
        ;;

    3)
        echo ""
        echo "Authentication Status"
        echo "===================="
        echo ""

        if [ -f "$CONFIG_DIR/credentials" ]; then
            echo "API key configured (credentials file)"
            source "$CONFIG_DIR/credentials" 2>/dev/null
            if [ -n "$OPENAI_API_KEY" ]; then
                echo "  Key: ${OPENAI_API_KEY:0:10}...${OPENAI_API_KEY: -4}"
            fi
        fi

        if [ -f "$CONFIG_DIR/auth.json" ]; then
            if grep -q "OPENAI_API_KEY" "$CONFIG_DIR/auth.json" 2>/dev/null; then
                echo "API Key configured (auth.json)"
            fi
        fi

        if [ -n "$OPENAI_API_KEY" ] && [ ! -f "$CONFIG_DIR/credentials" ]; then
            echo "API key set via environment variable"
            echo "  Key: ${OPENAI_API_KEY:0:10}...${OPENAI_API_KEY: -4}"
        fi

        if [ ! -f "$CONFIG_DIR/credentials" ] && [ ! -f "$CONFIG_DIR/auth.json" ] && [ -z "$OPENAI_API_KEY" ]; then
            echo "Not authenticated"
            echo ""
            echo "Run 'codex-auth' and choose option 1 or 2"
        fi

        echo ""
        ;;

    *)
        echo "Invalid choice"
        exit 1
        ;;
esac
